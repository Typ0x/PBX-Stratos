import os
import re
import subprocess
import sys
import time
import urllib.error
import urllib.request
from datetime import datetime, timezone
from getpass import getpass
from pathlib import Path
from typing import Any

# Force UTF-8 on stdout/stderr. The CLI prints box-drawing characters
# (─ │ ✓ etc.) in its banners; on a Windows console defaulting to
# cp1252 those raise UnicodeEncodeError and crash the script. Python
# ≥3.7 exposes TextIOWrapper.reconfigure; guarded for safety.
for _stream in (sys.stdout, sys.stderr):
    _rc = getattr(_stream, "reconfigure", None)
    if _rc is not None:
        try:
            _rc(encoding="utf-8")
        except (ValueError, OSError):
            pass

# ─── paths + constants ────────────────────────────────────────────────
REPO_ROOT = Path(__file__).resolve().parent
LAB_DIR = REPO_ROOT / "lab"
RUNNERS = LAB_DIR / "runners"

# Layer 3 runtime root for the lab. Honors the STRATOS_LAB_HOME env var
# first (set by profiles/stratos.{ps1,sh} and bear-watch/pm2.config.cjs),
# then falls back to <repo>/runtime/lab/. The legacy ~/.pbx-lab/ path is
# NOT used as fallback under the three-layer architecture — runtime data
# ships with the install, not in $HOME.
HOME = Path.home()
