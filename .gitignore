# PBX Stratos — .gitignore
#
# Per the three-layer architecture (see CLAUDE.md):
#   Layer 1 (FRAMEWORK)  → committed; this file shapes what's NOT in it
#   Layer 2 (CONTEXT)    → per-user; never committed
#   Layer 3 (RUNTIME)    → operational data; never committed

# === Layer 2 — per-user adaptive memory (never ships) ===
_context/

# === Layer 3 — operational data (never ships) ===
runtime/

# Legacy home-dir paths (pre-migration; only included so a stray
# write to ~/.pbx-lab or ~/.pbx-bots inside the repo can't sneak in)
.pbx-bots/
.pbx-lab/

# === Secrets — NEVER commit these ===
.env
.env.*
.env.local
.env.*.local
# Allow the documented example file (no real secrets in it).
!.env.example
*.key
*.pem
*-private*
*credentials*
gemini-key
helius-key

# Wallet files
*.enc
wallets/
*.keypair.json
bot-keypair.json

# === Build / dev artifacts ===
node_modules/
.npm/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
package-lock.json.bak

# TypeScript
*.tsbuildinfo
dist/
build/

# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
develop-eggs/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg
.venv/
venv/
env/
.pytest_cache/
.mypy_cache/

# === Bootstrap / setup runtime artifacts ===
.tooling/
_bootstrap_log.txt
_srvr_test.txt
_test_server.txt

# === Stray runtime files (defensive — should live under runtime/) ===
state/
alerts.jsonl
nav-history.jsonl
paper-trades.jsonl
paper-trade-heartbeat
aqi-snapshot.json
daily-digest-*.md
backups/

# === Generated dashboard artifacts ===
active-theme.css
ecosystem.config.js.lock
.pm2/

# === Screenshot output (regenerable) ===
screenshots/

# === Logs + scratch ===
*.log
*_log.txt
*.tmp
*.bak
*.bak-baseline
*.pid
_server.pid
_server_log.txt
_paper_trade_log.txt
.git-commit-msg.tmp

# === Editor / IDE ===
.vscode/
.idea/
*.swp
*.swo
*~

# === OS junk ===
.DS_Store
Thumbs.db
desktop.ini
