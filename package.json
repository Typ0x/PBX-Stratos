{
  "name": "pbx-stratos",
  "version": "0.3.0-dev",
  "private": true,
  "workspaces": [
    "bots",
    "packages/*"
  ],
  "scripts": {
    "setup": "node scripts/setup.mjs",
    "typecheck": "npm --workspace bots run typecheck",
    "server": "npm --workspace bots run server",
    "reset": "node scripts/reset-fresh.mjs",
    "reset:no-backup": "node scripts/reset-fresh.mjs --no-backup"
  },
  "devDependencies": {
    "playwright": "^1.49.1"
  }
}
